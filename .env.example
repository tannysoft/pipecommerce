# Database (Supabase via Hyperdrive in production)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pipecommerce

# Supabase (NEXT_PUBLIC_* exposed to browser — required for admin auth client)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Custom JWT for customer auth (storefront)
JWT_SECRET=change-me-32-chars-minimum-secret

# Cloudflare
CF_ACCOUNT_ID=
CF_API_TOKEN=
CF_ZONE_ID=

# Cloudflare R2 (S3-compatible)
# R2_ACCOUNT_ID = CF account id (Dashboard → R2 → "Account ID")
# R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY = R2 → Manage R2 API tokens (Object Read & Write)
# R2_PUBLIC_URL = R2 dev URL (Bucket → Settings → Public access → R2.dev subdomain)
#                 หรือ custom domain (cdn.yourapp.com) ใน production
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=pipecommerce
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Resend
RESEND_API_KEY=

# OAuth (customer auth, platform-level)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
FACEBOOK_OAUTH_CLIENT_ID=
FACEBOOK_OAUTH_CLIENT_SECRET=

# Beamcheckout
BEAM_API_BASE=https://api.beamcheckout.com

# Platform
PLATFORM_DOMAIN=pipecommerce.app
