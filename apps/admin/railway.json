{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm --filter @pipecommerce/admin... build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @pipecommerce/admin start",
    "healthcheckPath": "/login",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
