{
  "$schema": "https://railpack.com/schema.json",
  "build": {
    "buildCommand": "corepack enable && pnpm install --frozen-lockfile && pnpm --filter @pipecommerce/admin... build"
  },
  "deploy": {
    "startCommand": "pnpm --filter @pipecommerce/admin worker",
    "healthcheckPath": "/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
